# ─── Phase 1 ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Airtable — get from airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write,
#                  schema.bases:read, schema.bases:write
AIRTABLE_TOKEN=ypatcW9TVBCYPQZ6C0.fb6b450717afa113e750da4d1d77e4b6ffd1ac316e88ac83c20b45ea0024d158
AIRTABLE_BASE_ID=appyyRTcFRBZgXdwD/tblv7EZGCrb7jEHTg/viwt4ieOHfYInHGon

# WhatsApp group ID (format: 120363XXXXXXXXXX@g.us)
# Found automatically after first run — check console output.
WHATSAPP_GROUP_ID=

# Phone numbers in format 972501234567@c.us (no + sign)
ILANA_NUMBER=972XXXXXXXXX@c.us
OMRI_NUMBER=972XXXXXXXXX@c.us

# Path where WhatsApp session is stored (use a Render persistent disk path in prod)
SESSION_DATA_PATH=./.wwebjs_auth

# ─── Phase 2 (set ENABLE_PHASE2=true to activate) ────
ENABLE_PHASE2=false

ANTHROPIC_API_KEY=your_anthropic_api_key_here
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=whatsapp-household-bot
